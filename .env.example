# Template environment — salin ke .env atau .env.local lalu isi nilai asli:
#   cp .env.example .env.local
#
# Daftar variabel harus sesuai lib/env.ts (validasi @t3-oss/env-core).

# --- PostgreSQL (Prisma) ---
DATABASE_URL=
SHADOW_DATABASE_URL=

# --- Better Auth ---
# URL publik aplikasi, mis. http://localhost:3000
BETTER_AUTH_URL=
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- UploadThing ---
UPLOADTHING_TOKEN=

# --- Supabase (client, NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
